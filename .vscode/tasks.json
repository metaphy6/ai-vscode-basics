{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Agent: Session Bootstrap",
      "type": "shell",
      "command": "xops/agent/session-bootstrap.sh",
      "presentation": { "reveal": "always", "panel": "dedicated" },
      "problemMatcher": []
    },
    {
      "label": "Agent: Track (append row)",
      "type": "shell",
      "command": "make",
      "args": ["track.add", "ACTION=note", "SUMMARY=${input:summary}"],
      "presentation": { "reveal": "always" },
      "problemMatcher": []
    },
    {
      "label": "Git: Dry preview",
      "type": "shell",
      "command": "make",
      "args": ["git.dry"],
      "presentation": { "reveal": "always" },
      "problemMatcher": []
    },
    {
      "label": "Git: Commit + push (human-run)",
      "type": "shell",
      "command": "make",
      "args": ["git"],
      "presentation": { "reveal": "always" },
      "problemMatcher": []
    },
    {
      "label": "Doctor: Verify framework",
      "type": "shell",
      "command": "make",
      "args": ["doctor"],
      "presentation": { "reveal": "always" },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "summary",
      "type": "promptString",
      "description": "Conventional-commit-style summary (e.g. 'chore: tidy README')"
    }
  ]
}
